<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Date Converter - Nepal Dairy NDS</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .dc-card { max-width: 560px; margin: 0 auto; }
    .dc-tabs { display: flex; gap: 0; margin-bottom: 0; border-radius: 8px 8px 0 0; overflow: hidden; }
    .dc-tab {
      flex: 1; padding: 12px; text-align: center; cursor: pointer;
      background: #e8eaf6; font-size: 14px; font-weight: 600; color: #555;
      border: 1px solid #c5cae9; transition: background 0.2s;
      user-select: none;
    }
    .dc-tab.active { background: #1a237e; color: #fff; border-color: #1a237e; }
    .dc-tab:first-child { border-radius: 8px 0 0 0; }
    .dc-tab:last-child  { border-radius: 0 8px 0 0; }
    .dc-panel { display: none; }
    .dc-panel.active { display: block; }
    .dc-row { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; }
    .dc-field { display: flex; flex-direction: column; gap: 5px; }
    .dc-field label { font-size: 12px; font-weight: 600; color: #666; }
    .dc-field select, .dc-field input {
      padding: 9px 10px; border: 1px solid #ddd; border-radius: 6px;
      font-size: 14px; background: #fff;
    }
    .dc-field select:focus, .dc-field input:focus { outline: none; border-color: #3f51b5; }
    .dc-result {
      margin-top: 20px; padding: 16px 20px;
      background: #e8eaf6; border-radius: 8px; border-left: 4px solid #1a237e;
    }
    .dc-result .lbl { font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; }
    .dc-result .val-np { font-size: 22px; font-weight: 700; color: #1a237e; margin: 4px 0 2px; }
    .dc-result .val-en { font-size: 14px; color: #555; }
    .dc-result .val-ad { font-size: 22px; font-weight: 700; color: #1a237e; margin: 4px 0 2px; }
    .dc-arrow { font-size: 28px; color: #9fa8da; padding-bottom: 6px; }
    .dc-empty { color: #aaa; font-style: italic; font-size: 14px; }
    .dc-today-btn { font-size: 12px; color: #3f51b5; cursor: pointer; text-decoration: underline; background: none; border: none; }
  </style>
</head>
<body>
  <%- include('./partials/navbar') %>
  <main class="main-content">
    <div class="page-header">
      <h2>🔄 Date Converter &nbsp;<small style="font-size:14px;color:#888">BS ↔ AD</small></h2>
      <div id="nepaliDate"></div>
    </div>

    <div class="card dc-card">

      <!-- Tabs -->
      <div class="dc-tabs">
        <div class="dc-tab active" data-panel="bs2ad">
          🗓 Nepali → English<br><small style="font-weight:400">BS → AD</small>
        </div>
        <div class="dc-tab" data-panel="ad2bs">
          📆 English → Nepali<br><small style="font-weight:400">AD → BS</small>
        </div>
      </div>

      <!-- Panel 1: BS → AD -->
      <div class="dc-panel active" id="panel-bs2ad" style="padding:20px 0 0">
        <div class="dc-row">
          <div class="dc-field">
            <label>BS Year (वर्ष)</label>
            <select id="bs-year" style="width:110px"></select>
          </div>
          <div class="dc-field">
            <label>BS Month (महिना)</label>
            <select id="bs-month" style="width:160px"></select>
          </div>
          <div class="dc-field">
            <label>BS Day (गते)</label>
            <select id="bs-day" style="width:80px"></select>
          </div>
          <div class="dc-arrow">→</div>
        </div>
        <div id="result-bs2ad" class="dc-result" style="margin-top:16px">
          <div class="dc-empty">Select a BS date above</div>
        </div>
        <div style="margin-top:10px">
          <button class="dc-today-btn" id="btn-today-bs">Use today's BS date</button>
        </div>
      </div>

      <!-- Panel 2: AD → BS -->
      <div class="dc-panel" id="panel-ad2bs" style="padding:20px 0 0">
        <div class="dc-row">
          <div class="dc-field" style="flex:1;min-width:160px">
            <label>AD Date (YYYY-MM-DD)</label>
            <input type="date" id="ad-input" style="width:100%">
          </div>
          <div class="dc-arrow">→</div>
        </div>
        <div id="result-ad2bs" class="dc-result" style="margin-top:16px">
          <div class="dc-empty">Select an AD date above</div>
        </div>
        <div style="margin-top:10px">
          <button class="dc-today-btn" id="btn-today-ad">Use today's AD date</button>
        </div>
      </div>

    </div>
  </main>
  <script src="/nepali-calendar.js"></script>
  <script>
    // ── Conversion functions (same reference as nepali-calendar.js) ──
    const MONTHS_NP = ['बैशाख','जेठ','असार','साउन','भदौ','असोज','कात्तिक','मंसिर','पुष','माघ','फागुन','चैत'];
    const MONTHS_EN = ['Baishakh','Jestha','Ashadh','Shrawan','Bhadra','Ashwin','Kartik','Mangsir','Poush','Magh','Falgun','Chaitra'];
    const DAYS_NP   = ['आइतबार','सोमबार','मंगलबार','बुधबार','बिहीबार','शुक्रबार','शनिबार'];
    const DAYS_EN   = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

    let CAL_DATA = {
      2075:[31,32,31,32,31,30,30,29,30,29,30,30],
      2076:[31,32,31,32,31,30,30,30,29,29,30,30],
      2077:[31,32,31,31,31,30,30,29,30,29,30,30],
      2078:[31,31,32,31,31,31,30,30,29,30,29,31],
      2079:[31,32,31,32,31,30,30,30,29,29,30,30],
      2080:[31,32,31,32,31,30,30,30,29,29,30,30],
      2081:[31,31,32,31,31,31,30,29,30,29,30,30],
      2082:[31,32,31,32,31,30,30,30,29,30,30,30],
      2083:[31,31,32,32,31,30,30,30,29,30,30,30],
      2084:[31,31,32,32,31,30,30,30,29,30,30,30],
      2085:[31,32,31,32,31,30,30,29,30,29,30,30],
      2086:[31,32,31,32,31,30,30,30,29,29,30,31],
    };

    fetch('/api/nepalical').then(r=>r.json()).then(d=>{
      if(d && Object.keys(d).length){ Object.assign(CAL_DATA,d); populateBsYear(); }
    }).catch(()=>{});

    const REF_AD = new Date(2000,3,14);

    function getmd(y,m){ return (CAL_DATA[y]&&CAL_DATA[y][m]!==undefined)?CAL_DATA[y][m]:[31,31,32,32,31,30,30,29,30,29,30,30][m]; }

    function bsToAd(bY,bM,bD){
      const RY=2057,RM=0,RD=1;
      const cmp=bY!==RY?bY-RY:bM!==RM?bM-RM:bD-RD;
      if(!cmp) return new Date(REF_AD);
      let days=0;
      if(cmp>0){
        let y=RY,m=RM,d=RD;
        if(y===bY&&m===bM){days=bD-d;}
        else{days=getmd(y,m)-d+1;if(++m>=12){m=0;y++;}while(!(y===bY&&m===bM)){days+=getmd(y,m);if(++m>=12){m=0;y++;}}days+=bD-1;}
        return new Date(REF_AD.getTime()+days*86400000);
      } else {
        let y=bY,m=bM,d=bD;
        if(y===RY&&m===RM){days=RD-d;}
        else{days=getmd(y,m)-d+1;if(++m>=12){m=0;y++;}while(!(y===RY&&m===RM)){days+=getmd(y,m);if(++m>=12){m=0;y++;}}days+=RD-1;}
        return new Date(REF_AD.getTime()-days*86400000);
      }
    }

    function adToBs(ad){
      const diff=Math.round((ad-REF_AD)/86400000);
      let y=2057,m=0,d=1,r=diff;
      if(r>=0){while(r>0){const md=getmd(y,m),l=md-d+1;if(r>=l){r-=l;d=1;if(++m>=12){m=0;y++;}}else{d+=r;r=0;}}}
      else{r=-r;while(r>0){if(r>=d){r-=d;if(--m<0){m=11;y--;}d=getmd(y,m);}else{d-=r;r=0;}}}
      return {year:y,month:m,day:d};
    }

    function toNp(n){ return String(n).replace(/\d/g,c=>'०१२३४५६७८९'[c]); }
    function pad2(n){ return n<10?'0'+n:''+n; }
    function fmtAD(d){ return d.getFullYear()+'-'+pad2(d.getMonth()+1)+'-'+pad2(d.getDate()); }

    // ── Populate year/month/day selects ──
    function populateBsYear(){
      const sel = document.getElementById('bs-year');
      const cur = sel.value;
      sel.innerHTML = '';
      Object.keys(CAL_DATA).sort((a,b)=>a-b).forEach(y=>{
        const o=document.createElement('option');
        o.value=y; o.textContent=y+' BS ('+toNp(y)+')';
        sel.appendChild(o);
      });
      if(cur) sel.value=cur;
      updateBsMonth();
    }

    function updateBsMonth(){
      const y = parseInt(document.getElementById('bs-year').value);
      const mSel = document.getElementById('bs-month');
      const cur = mSel.value;
      mSel.innerHTML = '';
      MONTHS_NP.forEach((mn,i)=>{
        const o=document.createElement('option');
        o.value=i; o.textContent=(i+1)+'. '+mn+' / '+MONTHS_EN[i];
        mSel.appendChild(o);
      });
      if(cur!=='') mSel.value=cur;
      updateBsDay();
    }

    function updateBsDay(){
      const y = parseInt(document.getElementById('bs-year').value);
      const m = parseInt(document.getElementById('bs-month').value);
      const dSel = document.getElementById('bs-day');
      const cur = parseInt(dSel.value)||1;
      const dim = getmd(y,m);
      dSel.innerHTML = '';
      for(let d=1;d<=dim;d++){
        const o=document.createElement('option');
        o.value=d; o.textContent=d+' ('+toNp(d)+')';
        dSel.appendChild(o);
      }
      dSel.value = Math.min(cur, dim);
      doConvertBS();
    }

    function doConvertBS(){
      const y=parseInt(document.getElementById('bs-year').value);
      const m=parseInt(document.getElementById('bs-month').value);
      const d=parseInt(document.getElementById('bs-day').value);
      if(!y||isNaN(m)||!d) return;
      const ad = bsToAd(y,m,d);
      const dow = ad.getDay();
      const box = document.getElementById('result-bs2ad');
      box.innerHTML = `
        <div class="lbl">Nepali Date (बि.सं.)</div>
        <div class="val-np">${toNp(d)} ${MONTHS_NP[m]} ${toNp(y)}</div>
        <div class="val-en">${d} ${MONTHS_EN[m]} ${y} BS &nbsp;·&nbsp; ${DAYS_NP[dow]} / ${DAYS_EN[dow]}</div>
        <div style="margin-top:10px;padding-top:10px;border-top:1px solid #c5cae9">
          <div class="lbl">English Date (ई.सं.)</div>
          <div class="val-ad">${fmtAD(ad)}</div>
          <div class="val-en">${ad.toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</div>
        </div>`;
    }

    function doConvertAD(){
      const v = document.getElementById('ad-input').value;
      if(!v) return;
      const ad = new Date(v+'T00:00:00');
      if(isNaN(ad)) return;
      const bs = adToBs(ad);
      const dow = ad.getDay();
      const box = document.getElementById('result-ad2bs');
      box.innerHTML = `
        <div class="lbl">English Date (ई.सं.)</div>
        <div class="val-ad">${fmtAD(ad)}</div>
        <div class="val-en">${ad.toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</div>
        <div style="margin-top:10px;padding-top:10px;border-top:1px solid #c5cae9">
          <div class="lbl">Nepali Date (बि.सं.)</div>
          <div class="val-np">${toNp(bs.day)} ${MONTHS_NP[bs.month]} ${toNp(bs.year)}</div>
          <div class="val-en">${bs.day} ${MONTHS_EN[bs.month]} ${bs.year} BS &nbsp;·&nbsp; ${DAYS_NP[dow]} / ${DAYS_EN[dow]}</div>
        </div>`;
    }

    // ── Tab switching ──
    document.querySelectorAll('.dc-tab').forEach(tab=>{
      tab.addEventListener('click',()=>{
        document.querySelectorAll('.dc-tab').forEach(t=>t.classList.remove('active'));
        document.querySelectorAll('.dc-panel').forEach(p=>p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('panel-'+tab.dataset.panel).classList.add('active');
      });
    });

    // ── Events ──
    document.getElementById('bs-year').addEventListener('change', updateBsMonth);
    document.getElementById('bs-month').addEventListener('change', updateBsDay);
    document.getElementById('bs-day').addEventListener('change', doConvertBS);
    document.getElementById('ad-input').addEventListener('input', doConvertAD);
    document.getElementById('ad-input').addEventListener('change', doConvertAD);

    // Today buttons
    document.getElementById('btn-today-bs').addEventListener('click',()=>{
      const bs = adToBs(new Date());
      document.getElementById('bs-year').value = bs.year;
      updateBsMonth();
      document.getElementById('bs-month').value = bs.month;
      updateBsDay();
      document.getElementById('bs-day').value = bs.day;
      doConvertBS();
    });
    document.getElementById('btn-today-ad').addEventListener('click',()=>{
      document.getElementById('ad-input').value = fmtAD(new Date());
      doConvertAD();
    });

    // ── Init ──
    document.addEventListener('DOMContentLoaded',()=>{
      populateBsYear();
      // Default to today
      const bs = adToBs(new Date());
      document.getElementById('bs-year').value = bs.year;
      updateBsMonth();
      document.getElementById('bs-month').value = bs.month;
      updateBsDay();
      document.getElementById('bs-day').value = bs.day;
      doConvertBS();

      document.getElementById('ad-input').value = fmtAD(new Date());
      doConvertAD();
    });
  </script>
</body>
</html>
