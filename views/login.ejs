<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Nepal Dairy NDS</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-logo"><img src="/logo.png" alt="Nepal Dairy NDS" style="height:60px;width:auto;object-fit:contain;"></div>
    <h1 class="login-title">Nepal Dairy</h1>
    <p class="login-subtitle">NDS Modern Foods Pvt. Ltd.</p>
    <div class="nepali-date-login" id="nepaliDate"></div>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" class="login-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" required autofocus placeholder="Enter username">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required placeholder="Enter password">
      </div>
      <button type="submit" class="btn-primary btn-full">Login</button>
    </form>
    <div class="login-footer">
      <small>Default: admin / admin123 &nbsp;|&nbsp; labuser / lab123 &nbsp;|&nbsp; salesuser / sales123</small>
    </div>
  </div>
  <script src="/nepali-calendar.js"></script>
</body>
</html>
