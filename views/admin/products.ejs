<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products - Nepal Dairy NDS</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="page-header"><h2>📦 Product Management</h2></div>
    <div class="card">
      <h3>Add New Product</h3>
      <form method="POST" action="/admin/products/add" class="form-grid">
        <div class="form-group">
          <label>Product Name</label>
          <input type="text" name="name" required placeholder="e.g. Full Cream Milk">
        </div>
        <div class="form-group">
          <label>Category</label>
          <input type="text" name="category" placeholder="e.g. Milk, Fat Products">
        </div>
        <div class="form-group">
          <label>Unit</label>
          <input type="text" name="unit" placeholder="e.g. Liter, Kg">
        </div>
        <div class="form-group">
          <label>Price (Rs.)</label>
          <input type="number" step="0.01" name="price" placeholder="e.g. 85">
        </div>
        <div class="form-full">
          <button type="submit" class="btn-primary">Add Product</button>
        </div>
      </form>
    </div>
    <div class="card">
      <h3>All Products</h3>
      <table class="data-table">
        <thead>
          <tr><th>#</th><th>Name</th><th>Category</th><th>Unit</th><th>Price (Rs.)</th><th>Action</th></tr>
        </thead>
        <tbody>
          <% products.forEach((p, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><%= p.name %></td>
            <td><%= p.category || '-' %></td>
            <td><%= p.unit || '-' %></td>
            <td>Rs. <%= p.price %></td>
            <td>
              <form method="POST" action="/admin/products/delete/<%= p.id %>" onsubmit="return confirm('Delete product?')">
                <button class="btn-danger-sm">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (products.length === 0) { %>
          <tr><td colspan="6" class="empty">No products added yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
  <script src="/nepali-calendar.js"></script>
</body>
</html>
