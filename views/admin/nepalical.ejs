<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nepali Calendar - Nepal Dairy NDS</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .cal-table th { background:#1a237e;color:#fff;padding:8px 10px;font-size:12px; }
    .cal-table td { padding:7px 10px;font-size:13px; }
    .cal-table input[type=number] { width:60px;padding:4px 6px;border:1px solid #ccc;border-radius:4px;text-align:center; }
    .year-block { margin-bottom:30px; }
    .year-title { display:flex;align-items:center;justify-content:space-between;margin-bottom:8px; }
    .year-title h3 { font-size:17px;color:#1a237e; }
    .cum-cell { color:#888;font-size:12px; }
    .filter-bar { display:flex;gap:10px;align-items:center;margin-bottom:18px;flex-wrap:wrap; }
    .month-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:16px; }
    .month-card { background:#f5f5f5;border-radius:8px;padding:12px;text-align:center; }
    .month-card label { display:block;font-size:12px;font-weight:700;color:#555;margin-bottom:6px; }
    .month-card input { width:70px;padding:6px;border:1px solid #ccc;border-radius:4px;text-align:center;font-size:15px;font-weight:700; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="page-header">
      <h2>📅 Nepali Calendar (RNEPALICAL)</h2>
      <div id="nepaliDate"></div>
    </div>

    <% if (msg) { %><div class="alert alert-success"><%= msg %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <!-- Add New Year -->
    <div class="card">
      <h3>Add New BS Year</h3>
      <form method="POST" action="/admin/nepalical/add-year" id="addYearForm">
        <div class="filter-bar">
          <div class="form-group">
            <label>BS Year</label>
            <input type="number" name="bs_year" id="addYear" min="2070" max="2100" placeholder="e.g. 2084" style="width:120px" required>
          </div>
        </div>
        <div class="month-grid">
          <% BS_MONTHS.forEach((m, i) => { %>
          <div class="month-card">
            <label><%= m %> (Month <%= i+1 %>)</label>
            <input type="number" name="days" min="28" max="32" value="31" required>
          </div>
          <% }) %>
        </div>
        <div style="margin-top:16px">
          <button type="submit" class="btn-primary">Add Year to Calendar</button>
        </div>
      </form>
    </div>

    <!-- Filter by Year -->
    <div class="card">
      <div class="filter-bar">
        <strong>Filter by Year:</strong>
        <a href="/admin/nepalical" class="btn-primary" style="padding:6px 14px;font-size:13px;<%= !filterYear ? 'background:#283593' : '' %>">All</a>
        <% years.forEach(y => { %>
          <a href="/admin/nepalical?year=<%= y %>"
            class="btn-primary"
            style="padding:6px 14px;font-size:13px;<%= filterYear == y ? 'background:#e53935' : '' %>">
            <%= y %>
          </a>
        <% }) %>
      </div>

      <% Object.keys(grouped).sort().forEach(year => { %>
      <div class="year-block">
        <div class="year-title">
          <h3>BS Year <%= year %></h3>
          <form method="POST" action="/admin/nepalical/delete-year/<%= year %>"
            onsubmit="return confirm('Delete all data for BS <%= year %>?')">
            <button class="btn-danger-sm">Delete Year</button>
          </form>
        </div>
        <div class="table-wrap">
          <table class="data-table cal-table">
            <thead>
              <tr>
                <th>Month</th>
                <th>Month Name</th>
                <th>Days</th>
                <th>Cum. Start Days</th>
                <th>Cum. Days</th>
                <th>Update</th>
              </tr>
            </thead>
            <tbody>
              <% grouped[year].forEach(row => { %>
              <tr>
                <td><%= row.bs_month %></td>
                <td><%= row.month_name %></td>
                <td><strong><%= row.days %></strong></td>
                <td class="cum-cell"><%= row.cumstartdays %></td>
                <td class="cum-cell"><%= row.cumdays %></td>
                <td>
                  <form method="POST" action="/admin/nepalical/update/<%= row.id %>"
                    style="display:flex;gap:6px;align-items:center">
                    <input type="number" name="days" value="<%= row.days %>"
                      min="28" max="32" style="width:60px;padding:4px 6px;border:1px solid #ccc;border-radius:4px;text-align:center">
                    <button type="submit" class="btn-primary" style="padding:4px 12px;font-size:12px">Update</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr style="background:#e8eaf6;font-weight:700">
                <td colspan="2">Total Days in Year</td>
                <td><%= grouped[year].reduce((s,r)=>s+r.days,0) %></td>
                <td class="cum-cell"><%= grouped[year][0] ? grouped[year][0].cumstartdays : '' %></td>
                <td class="cum-cell"><%= grouped[year][grouped[year].length-1] ? grouped[year][grouped[year].length-1].cumdays : '' %></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
      <% }) %>

      <% if (Object.keys(grouped).length === 0) { %>
        <p class="empty">No calendar data found. Add a BS year above.</p>
      <% } %>
    </div>
  </main>
  <script src="/nepali-calendar.js"></script>
</body>
</html>
